[user]
	name = Jason Riddle

[alias]
	co = checkout
	cob = checkout -b
	psuh = push

[core]
	editor = vim
	excludesfile = ~/.gitignore-global
	attributesfile = ~/.gitattributes-global

[push]
	# Default push to update current branch on remote.
	default = current

[fetch]
	# Always prune refs when fetching.
	prune = true

[color]
	ui = always

# git status
[color "status"]
	added = green
	changed = yellow
	untracked = cyan

# git branch -vv
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[diff "plist"]
	textconv = plutil -convert xml1 -o -

[include]
	path = ~/.gitconfig-diff-highlight

[ghq]
	root = ~/code/src
